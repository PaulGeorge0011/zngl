# ===== 本地开发环境配置 =====
# 生产配置已备份到 .env.production.bak

# Database - 使用 SQLite 进行本地开发（无需安装 PostgreSQL）
USE_SQLITE_DEV=True
DB_NAME=zs2_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# AI（如果本地没有 Ollama 可以留空，相关功能将不可用但不影响其他功能）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:35b

# RAGflow（本地开发可留空）
RAGFLOW_BASE_URL=
RAGFLOW_API_KEY=
RAGFLOW_DATASET_ID=
RAGFLOW_QUALITY_DATASET_ID=
RAGFLOW_SAFETY_DATASET_ID=

# Django
SECRET_KEY=django-insecure-local-dev-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Cookie security（本地开发用 HTTP，不启用 Secure）
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# SSO 关闭（本地开发使用密码登录）
SSO_ENABLED=False
